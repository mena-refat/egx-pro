# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_URL="https://your-app-url.run.app"

# ── Database (Supabase) ────────────────────────────────────────────────────────
# Pooler connection — used by Prisma at runtime (supports connection pooling)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
# Direct connection — used by Prisma Migrate / db push (bypasses pooler)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_PEPPER="your_auth_pepper_here"
# Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET="your_jwt_access_token_secret_here"
# Generate with: openssl rand -hex 64
REFRESH_TOKEN_SECRET="your_refresh_token_secret_here"
# Must differ from JWT_ACCESS_TOKEN_SECRET — generate with: openssl rand -hex 32
ADMIN_JWT_SECRET="your_admin_jwt_secret_here"

# ── Admin Seed ─────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@yourdomain.com"
SUPER_ADMIN_PASSWORD="your_super_admin_password_here"

# ── OAuth (Google) ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── AI ────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY="sk-ant-api03-your_claude_api_key_here"

# ── External APIs ─────────────────────────────────────────────────────────────
NEWS_API_KEY="your_news_api_key_here"
EXCHANGERATE_API_KEY="your_exchangerate_api_key_here"
TWELVE_DATA_API_KEY="your_twelve_data_api_key_here"

# ── Cache (Upstash Redis) — optional, falls back to in-memory ─────────────────
# UPSTASH_REDIS_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_TOKEN="your_upstash_redis_token_here"
