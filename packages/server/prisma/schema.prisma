generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

// Administration
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// User plans — lowercase to match existing string literals in code
enum UserPlan {
  free
  pro
  yearly
  ultra
  ultra_yearly
}

// User preferences
enum RiskTolerance {
  conservative
  moderate
  aggressive
}

// Goals
enum GoalStatus {
  active
  completed
}

// Referrals
enum ReferralStatus {
  pending
  completed
}

// Blocked identifiers — uppercase to match existing code
enum BlockedIdentifierType {
  EMAIL
  PHONE
  EMAIL_DOMAIN
}

// Idempotency — uppercase to match existing code
enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// Social
enum FollowStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// Predictions
enum PredictionDir {
  UP
  DOWN
}

enum PredictionTime {
  WEEK
  MONTH
  THREE_MONTHS
  SIX_MONTHS
  NINE_MONTHS
  YEAR
}

enum PredictionStatus {
  ACTIVE
  HIT
  MISSED
  EXPIRED
}

/// وضع التوقع: حجم التحرك (الوضع الأساسي) أو سعر محدد (للمدفوعين فقط)
enum PredictionMode {
  TIER   // يتوقع حجم التحرك (LIGHT/MEDIUM/STRONG/EXTREME)
  EXACT  // يتوقع سعراً بعينه وتاريخ انتهاء مخصص — Pro/Ultra فقط
}

/// حجم التحرك المتوقع
enum MoveTier {
  LIGHT    // خفيف  : نطاق يعتمد على الإطار الزمني
  MEDIUM   // متوسط
  STRONG   // قوي
  EXTREME  // متطرف
}

enum UserRank {
  BEGINNER
  ANALYST
  SENIOR
  EXPERT
  LEGEND
}

// Support
enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Market
enum GicsSector {
  INFORMATION_TECHNOLOGY
  HEALTH_CARE
  FINANCIALS
  CONSUMER_DISCRETIONARY
  CONSUMER_STAPLES
  ENERGY
  INDUSTRIALS
  MATERIALS
  UTILITIES
  REAL_ESTATE
  COMMUNICATION_SERVICES
}

enum NewsSourceType {
  NEWS_API
  GOOGLE_RSS
  EGX_DISCLOSURE
}

// ─────────────────────────────────────────────────────────────────────────────
// Market Data
// ─────────────────────────────────────────────────────────────────────────────

model Stock {
  id                String      @id @default(cuid())
  ticker            String      @unique
  nameAr            String
  nameEn            String
  sector            GicsSector?
  description       String?
  isShariaCompliant Boolean?

  @@index([sector])
  @@index([isShariaCompliant])
}

// ─────────────────────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id    Int     @id @default(autoincrement())
  email String? @unique
  phone String? @unique

  // ── Authentication ──────────────────────────────────────────────────────
  passwordHash         String?
  salt                 String?
  isEmailVerified      Boolean   @default(false)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorEnabledAt   DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastPasswordChangeAt DateTime?
  mustChangePassword   Boolean   @default(false)
  mustSetup2FA         Boolean   @default(false)
  // Password-policy flags set per-user by admin
  pwdMinLength Boolean @default(false)
  pwdUppercase Boolean @default(false)
  pwdLowercase Boolean @default(false)
  pwdSymbols   Boolean @default(false)

  // ── Profile ─────────────────────────────────────────────────────────────
  fullName             String?
  username             String?   @unique
  avatarUrl            String?
  userTitle            String    @default("ناشئ")
  hearAboutUs          String?
  lastUsernameChangeAt DateTime?
  usernameChangeCount  Int       @default(0)
  isFirstLogin         Boolean   @default(true)
  isPrivate            Boolean   @default(true)
  showPortfolio        Boolean   @default(true)

  // ── Preferences ─────────────────────────────────────────────────────────
  language            String         @default("system")
  theme               String         @default("system")
  riskTolerance       RiskTolerance? @default(moderate)
  investmentHorizon   Int?           @default(5)
  monthlyBudget       Float?         @default(0)
  shariaMode          Boolean        @default(false)
  onboardingCompleted Boolean        @default(false)
  interestedSectors   Json?
  investorProfile     Json?

  // ── Notification Preferences ─────────────────────────────────────────────
  notifySignals      Boolean @default(true)
  notifyPortfolio    Boolean @default(true)
  notifyNews         Boolean @default(true)
  notifyAchievements Boolean @default(true)
  notifyGoals        Boolean @default(true)
  pushToken          String?
  pushPlatform       String?

  // ── Plan & Billing ───────────────────────────────────────────────────────
  plan                    UserPlan  @default(free)
  planExpiresAt           DateTime?
  planSetByAdmin          Boolean   @default(false)
  aiAnalysisUsedThisMonth Int       @default(0)
  aiAnalysisResetDate     DateTime?

  // ── Referral ─────────────────────────────────────────────────────────────
  referralCode             String?   @unique
  referredBy               String?
  referralUsed             String?
  totalReferrals           Int       @default(0)
  referralProDaysRemaining Int       @default(0)
  referralProExpiresAt     DateTime?
  freeReferralRewarded     Boolean   @default(false)

  // ── Activity & Gamification ───────────────────────────────────────────────
  lastLoginAt        DateTime?
  lastLoginIp        String?
  loginStreak        Int      @default(0)
  unseenAchievements String[] @default([])
  googlePlayToken    String? /// Latest Google Play purchaseToken for RTDN lookup

  // ── Soft Delete ───────────────────────────────────────────────────────────
  isDeleted            Boolean   @default(false)
  deletedAt            DateTime?
  deletionScheduledFor DateTime?

  // ── Moderation ───────────────────────────────────────────────────────────
  warningCount Int       @default(0)
  isSuspended  Boolean   @default(false)
  suspendedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────────
  analyses            Analysis[]
  auditLogs           AuditLog[]
  abuseReports        AbuseReport[]
  discountUsages      DiscountUsage[]
  followsReceived     Follow[]             @relation("FollowFollowing")
  followsSent         Follow[]             @relation("FollowFollower")
  goals               Goal[]
  idempotencyKeys     IdempotencyKey[]
  notifications       Notification[]
  paymentTransactions PaymentTransaction[]
  portfolios          Portfolio[]
  predictionLikes     PredictionLike[]
  predictions         Prediction[]
  predictionStats     UserPredictionStats?
  referralsSent       Referral[]           @relation("ReferralsSent")
  referredReferral    Referral?            @relation("ReferralReceived")
  refreshTokens       RefreshToken[]
  supportTickets      SupportTicket[]
  watchlists          Watchlist[]

  @@index([isDeleted, deletionScheduledFor])
  @@index([isDeleted, lastLoginAt])
  @@index([isDeleted, plan, planExpiresAt])
  @@index([googlePlayToken])
  @@index([username])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Admins
// ─────────────────────────────────────────────────────────────────────────────

model Admin {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  salt         String
  fullName     String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  permissions  String[]  @default([])

  // ── Authentication ──────────────────────────────────────────────────────
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  mustChangePassword Boolean   @default(false)
  mustSetup2FA       Boolean   @default(false)
  // Password-policy flags set per-admin
  pwdMinLength Boolean @default(false)
  pwdUppercase Boolean @default(false)
  pwdLowercase Boolean @default(false)
  pwdSymbols   Boolean @default(false)
  tokenVersion Int     @default(0)
  lastLoginAt  DateTime?
  lastLoginIp  String?

  // ── Hierarchy ────────────────────────────────────────────────────────────
  createdBy     Int?
  managerId     Int?
  manager       Admin?  @relation("SupportTeam", fields: [managerId], references: [id])
  managedAgents Admin[] @relation("SupportTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs      AdminAuditLog[]
  quickReplies   QuickReply[]
  reportedAbuses         AbuseReport[]           @relation("AbuseReporter")
  reviewedAbuses         AbuseReport[]           @relation("AbuseReviewer")
  scheduledNotifications ScheduledNotification[]

  @@index([managerId])
  @@index([isDeleted])
}

model QuickReply {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdBy Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
}

// ─────────────────────────────────────────────────────────────────────────────
// Security & Audit
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique // store SHA-256 hash, never raw value
  userId     Int
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  deviceInfo String?
  deviceType String?
  browser    String?
  os         String?
  ipAddress  String?
  city       String?
  country    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRevoked, expiresAt])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    Int?
  action    String
  details   String?
  ipHash    String?  // hashed IP only — never store plain IP
  userAgent String?
  result    String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   Int
  action    String
  target    String?
  details   String?
  ipHash    String?  // hashed IP only — never store plain IP
  userAgent String?
  city      String?  // governorate/city from IP geolocation
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model BlockedIdentifier {
  id        String                @id @default(cuid())
  type      BlockedIdentifierType
  value     String
  reason    String?
  blockedBy Int?
  createdAt DateTime              @default(now())

  @@unique([type, value])
  @@index([type])
}

model IdempotencyKey {
  id             String            @id @default(cuid())
  userId         Int
  key            String
  method         String
  path           String
  requestHash    String
  status         IdempotencyStatus @default(PROCESSING)
  responseStatus Int?
  responseBody   Json?
  lockedAt       DateTime
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, status, expiresAt])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Portfolio & Goals
// ─────────────────────────────────────────────────────────────────────────────

model Portfolio {
  id        String   @id @default(uuid())
  userId    Int
  ticker    String
  shares    Float
  avgPrice  Float
  buyDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, ticker])
  @@index([ticker])
}

model Watchlist {
  id                      String    @id @default(uuid())
  userId                  Int
  ticker                  String
  targetPrice             Float?
  targetDirection         String?   @default("UP")   // "UP" | "DOWN"
  targetReachedNotifiedAt DateTime?
  createdAt               DateTime  @default(now())
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model Goal {
  id            String     @id @default(cuid())
  userId        Int
  title         String
  targetAmount  Float
  currentAmount Float      @default(0)
  currency      String     @default("EGP")
  deadline      DateTime?
  category      String
  status        GoalStatus @default(active)
  achievedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([deadline])
}

// ─────────────────────────────────────────────────────────────────────────────
// Analysis
// ─────────────────────────────────────────────────────────────────────────────

model Analysis {
  id              String    @id @default(uuid())
  userId          Int
  ticker          String
  content         String
  priceAtAnalysis Float?
  targetPrice     Float?
  stopLoss        Float?
  verdict         String?
  priceAfter7d    Float?
  priceAfter30d   Float?
  accuracyScore   Float?
  accuracyNote    String?
  checkedAt       DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, ticker])
  @@index([ticker, createdAt])
  @@index([checkedAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Social & Predictions
// ─────────────────────────────────────────────────────────────────────────────

model Follow {
  id          String       @id @default(cuid())
  followerId  Int
  followingId Int
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  follower    User         @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User         @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, status])
}

model Prediction {
  id              String           @id @default(cuid())
  userId          Int
  ticker          String
  direction       PredictionDir
  mode            PredictionMode   @default(TIER)
  // TIER mode
  moveTier        MoveTier?        // null when mode = EXACT
  timeframe       PredictionTime?  // null when mode = EXACT
  // EXACT mode
  targetPrice     Float?           // required when mode = EXACT
  priceAtCreation Float
  reason          String?
  expiresAt       DateTime         // TIER: computed from timeframe; EXACT: user-chosen
  isPublic        Boolean          @default(true)
  status          PredictionStatus @default(ACTIVE)
  resolvedAt      DateTime?
  resolvedPrice   Float?
  pointsEarned    Int?
  accuracyPct     Float?           // TIER: 0-100 tier accuracy; EXACT: 0-100 tolerance accuracy
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes           PredictionLike[]

  @@index([userId])
  @@index([userId, status])
  @@index([ticker, status])
  @@index([status, isPublic])
  @@index([status, expiresAt])
  @@index([userId, createdAt])
}

model PredictionLike {
  predictionId String
  userId       Int
  createdAt    DateTime   @default(now())
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([predictionId, userId])
  @@index([userId])
}

model UserPredictionStats {
  userId             Int      @id
  totalPredictions   Int      @default(0)
  correctPredictions Int      @default(0)
  totalPoints        Int      @default(0)
  accuracyRate       Float    @default(0)
  currentStreak      Int      @default(0)
  bestStreak         Int      @default(0)
  rank               UserRank @default(BEGINNER)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// Referrals
// ─────────────────────────────────────────────────────────────────────────────

model Referral {
  id             String         @id @default(cuid())
  referrerId     Int
  referredUserId Int            @unique
  status         ReferralStatus @default(pending)
  createdAt      DateTime       @default(now())
  referrer       User           @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser   User           @relation("ReferralReceived", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId, status, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    Int
  type      String
  title     String
  body      String
  route     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Billing & Discounts
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id        String   @id @default(cuid())
  paymobId  String   @unique
  userId    Int
  plan      String
  amountEGP Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model DiscountCode {
  id        String          @id @default(uuid())
  code      String          @unique
  type      String          // 'percentage' | 'fixed' | 'full'
  value     Float
  active    Boolean         @default(true)
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  usages    DiscountUsage[]

  @@index([active, expiresAt])
}

model DiscountUsage {
  userId       Int
  codeId       String
  usedAt       DateTime     @default(now())
  discountCode DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, codeId])
  @@index([codeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// News
// ─────────────────────────────────────────────────────────────────────────────

model NewsItem {
  id           String         @id @default(cuid())
  externalId   String         @unique
  title        String
  summary      String?
  source       String
  sourceType   NewsSourceType
  url          String
  publishedAt  DateTime
  fetchedAt    DateTime       @default(now())
  isMarketWide Boolean        @default(false)
  language     String?
  sentiment    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tickers      NewsTicker[]

  @@index([publishedAt])
  @@index([sourceType, publishedAt])
  @@index([isMarketWide, publishedAt])
}

model NewsTicker {
  newsId String
  ticker String
  news   NewsItem @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@id([newsId, ticker])
  @@index([ticker])
}

// ─────────────────────────────────────────────────────────────────────────────
// Support
// ─────────────────────────────────────────────────────────────────────────────

model SupportTicket {
  id                 String              @id @default(cuid())
  userId             Int
  subject            String
  message            String
  status             SupportTicketStatus @default(OPEN)
  priority           TicketPriority      @default(NORMAL)
  assignedTo         Int?
  assignedAt         DateTime?
  reply              String?
  repliedAt          DateTime?
  repliedBy          Int?
  replyRead          Boolean             @default(false)
  rating             Int?
  ratedAt            DateTime?
  escalatedAt        DateTime?
  escalatedBy        Int?
  escalationNote     String?
  escalatedToManager Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  abuseReports       AbuseReport[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@index([assignedTo, status])
  @@index([createdAt])
}

enum AbuseReportStatus {
  PENDING
  WARNED
  DISMISSED
}

model AbuseReport {
  id         Int               @id @default(autoincrement())
  ticketId   String
  userId     Int
  reporterId Int
  reviewerId Int?
  reason     String
  status     AbuseReportStatus @default(PENDING)
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  ticket     SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reporter   Admin             @relation("AbuseReporter", fields: [reporterId], references: [id])
  reviewer   Admin?            @relation("AbuseReviewer", fields: [reviewerId], references: [id])

  @@index([ticketId])
  @@index([userId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// News Analysis
// ─────────────────────────────────────────────────────────────────────────────

/// Persistent store for AI-generated news analysis results.
/// Keyed by SHA-256 of (title|description) so it survives Redis restarts.
/// Redis is still used as L1 hot cache (1h TTL); DB is the source of truth.
model NewsItemAnalysis {
  id          String   @id @default(cuid())
  /// SHA-256 of "title|description" — matches articleHash() in the service
  contentHash String   @unique
  /// Full NewsImpactAnalysis JSON (all stages including deepReport if present)
  result      Json
  /// impact_level from Stage 1 — useful for analytics queries
  impactLevel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([impactLevel])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Archive
// ─────────────────────────────────────────────────────────────────────────────

model ArchivedUser {
  id         String   @id @default(cuid())
  originalId String   @unique
  email      String?
  phone      String?
  username   String?
  name       String?
  userData   Json
  archivedAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduled Notifications
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationRepeat {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum ScheduledNotificationStatus {
  PENDING
  SENT
  CANCELLED
}

model ScheduledNotification {
  id          Int                         @id @default(autoincrement())
  title       String
  body        String
  plans       String[]                    @default([])
  scheduledAt DateTime
  repeat      NotificationRepeat          @default(NONE)
  nextSendAt  DateTime
  lastSentAt  DateTime?
  sentCount   Int                         @default(0)
  status      ScheduledNotificationStatus @default(PENDING)
  createdById Int
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  createdBy Admin @relation(fields: [createdById], references: [id])

  @@index([status, nextSendAt])
  @@index([createdById])
}
