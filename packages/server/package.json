{
  "name": "@borsa/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "tsx src/scripts/seed-sectors.ts",
    "db:seed-super": "tsx src/scripts/create-super-admin.ts",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.42.0",
    "@upstash/redis": "^1.36.3",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^146.0.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "p-queue": "^9.1.0",
    "pg": "^8.19.0",
    "prisma": "^6.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.9",
    "vite": "^6.2.0",
    "winston": "^3.19.0",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "xss": "^1.0.15",
    "yahoo-finance2": "^3.13.2",
    "zod": "^4.3.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@types/zxcvbn": "^4.4.5",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.0.18"
  }
}
