// ❌ WRONG — raw HTML
<button className="bg-purple-600 text-white px-4 py-2 rounded-lg">
  حفظ
</button>
<input
  type="email"
  className="border border-gray-300 rounded px-3 py-2 w-full"
  value={email}
  onChange={e => setEmail(e.target.value)}
