## 6. Forms — react-hook-form + Zod دايماً

```tsx
// ✅ CORRECT
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';

const goalSchema = z.object({
  title:        z.string().min(1, t('validation.required')).max(100),
  targetAmount: z.number({ invalid_type_error: t('validation.mustBeNumber') })
                 .positive(t('validation.mustBePositive'))
                 .max(100_000_000),
  category:     z.string().min(1, t('validation.required')),
  deadline:     z.string().datetime().optional(),
});

type GoalFormData = z.infer<typeof goalSchema>;

export function GoalFormModal({ onSubmit, onClose }: Props) {
  const { t } = useTranslation('common');
  const {
    register,
    handleSubmit,
    formState: { errors, isSubmitting },
    reset,
  } = useForm<GoalFormData>({ resolver: zodResolver(goalSchema) });

  const handleFormSubmit = async (data: GoalFormData) => {
    await onSubmit(data);
    reset();
    onClose();
  };

  return (
    <form onSubmit={handleSubmit(handleFormSubmit)}>
      <Input
        {...register('title')}
        placeholder={t('goals.titlePlaceholder')}
        error={errors.title?.message}
      />
      <Input
        {...register('targetAmount', { valueAsNumber: true })}
        type="number"
        error={errors.targetAmount?.message}
      />
      <Button type="submit" variant="primary" loading={isSubmitting}>
        {t('common.save')}
      </Button>
    </form>
  );
}

// ❌ WRONG — manual state للـ form
const [title, setTitle]         = useState('');
const [amount, setAmount]       = useState('');
const [titleError, setTitleError] = useState('');
const [loading, setLoading]     = useState(false);

const handleSubmit = async () => {
  if (!title) { setTitleError('مطلوب'); return; }
  setLoading(true);
  await createGoal({ title, amount: Number(amount) });
  setLoading(false);
};
```

