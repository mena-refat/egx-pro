## 8. AbortController — في كل useEffect فيه fetch

```tsx
// ✅ CORRECT
useEffect(() => {
  const controller = new AbortController();

  const load = async () => {
    try {
      const res = await api.get('/goals', { signal: controller.signal });
      setGoals(res.data.items);
    } catch (err: unknown) {
      if ((err as { code?: string }).code === 'ERR_CANCELED') return;
      setError(t('errors.loadFailed'));
    } finally {
      setLoading(false);
    }
  };

  load();
  return () => controller.abort(); // cleanup عند الـ unmount
}, [accessToken]);

// ❌ WRONG — بيعمل state update على component اتشال
useEffect(() => {
  api.get('/goals').then(res => {
    setGoals(res.data.items); // ❌ ممكن component يكون اتشال
    setLoading(false);
  });
}, []);
```

