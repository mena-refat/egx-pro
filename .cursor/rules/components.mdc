## 9. Event Listeners والـ Timers — cleanup دايماً

```tsx
// ✅ CORRECT — event listener
useEffect(() => {
  const handleClickOutside = (e: MouseEvent) => {
    if (ref.current && !ref.current.contains(e.target as Node)) {
      setOpen(false);
    }
  };
  document.addEventListener('mousedown', handleClickOutside);
  return () => document.removeEventListener('mousedown', handleClickOutside);
}, []);

// ✅ CORRECT — timeout
useEffect(() => {
  if (!visible) return;
  const id = setTimeout(() => setVisible(false), TIMEOUTS.toast);
  return () => clearTimeout(id);
}, [visible]);

// ✅ CORRECT — interval
useEffect(() => {
  const id = setInterval(fetchLivePrices, CACHE_TTL.prices * 1000);
  return () => clearInterval(id);
}, []);

// ✅ CORRECT — WebSocket
useEffect(() => {
  const ws = new WebSocket(WS_URL);
  ws.onmessage = handleMessage;
  return () => ws.close(); // cleanup
}, []);

// ❌ WRONG — memory leak
useEffect(() => {
  window.addEventListener('resize', handleResize);    // ❌ مش بيتشال
  setTimeout(() => setVisible(false), 3000);          // ❌ مش بيتكنسل
  setInterval(fetchPrices, 60_000);                   // ❌ بيفضل شغال
}, []);
```

