} catch (err: unknown) {
  if (import.meta.env.DEV) console.error('Failed to load goals:', err);
  setError(t('errors.loadFailed'));
}

// ❌ WRONG — console بدون guard
console.log('user:', user);
console.log('stocks loaded:', stocks.length);
console.error(err); // بيظهر في production
```

