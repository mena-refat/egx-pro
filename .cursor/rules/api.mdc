## 3. Service Rules

Service = كل الـ business logic. بيستخدم Repository. مش بيتعامل مع req أو res.

```ts
// ✅ CORRECT
export const GoalsService = {

  async getUserGoals(userId: string, page: number) {
    return GoalsRepository.findByUser(userId, page, 10);
  },

  async create(user: AuthUser, body: unknown) {
    const data = goalSchema.parse(body);
    if (!isPro(user)) {
      await GoalsRepository.enforceLimit(user.id);
    }
    const goal = await GoalsRepository.create(user.id, data);
    await AchievementService.checkGoalAchievements(user.id);
    return goal;
  },

  async update(userId: string, goalId: string, body: unknown) {
    const data = goalUpdateSchema.parse(body);
    const existing = await GoalsRepository.findOwned(goalId, userId);
    if (!existing) throw new AppError('NOT_FOUND', 404);
    return GoalsRepository.update(goalId, data);
  },

  async delete(userId: string, goalId: string) {
    const existing = await GoalsRepository.findOwned(goalId, userId);
    if (!existing) throw new AppError('NOT_FOUND', 404);
    await GoalsRepository.delete(goalId);
  },

};

// ❌ WRONG — prisma مباشرة داخل service
export const GoalsService = {
  async create(userId: string, body: unknown) {
    return prisma.goal.create({ data: { userId, ...body } }); // ❌ يروح في repository
  }
};
```

