## 8. Ownership Verification

كل query بـ id لازم تتحقق إن الـ resource بتاع الـ user الحالي.

```ts
// ✅ CORRECT — userId في الـ where clause نفسه
const goal = await prisma.goal.findUnique({
  where: { id: goalId, userId: req.user.id }
});
if (!goal) return res.status(404).json({ error: 'NOT_FOUND' });

// ✅ CORRECT — في الـ Repository
async findOwned(id: string, userId: string) {
  return prisma.goal.findUnique({ where: { id, userId } });
}

// ❌ WRONG — بتجيب الـ resource وبعدين تتحقق
const goal = await prisma.goal.findUnique({ where: { id: goalId } });
if (goal?.userId !== req.user.id) { // ❌ timing issue + extra query
  return res.status(403).json({ error: 'FORBIDDEN' });
}

// ❌ WRONG — مفيش تحقق خالص
const goal = await prisma.goal.findUnique({ where: { id: goalId } });
await prisma.goal.delete({ where: { id: goalId } }); // ❌ أي حد يقدر يمسح
```

