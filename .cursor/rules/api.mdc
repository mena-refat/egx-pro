## 2. Controller Rules

Controller = request/response فقط. صفر business logic. صفر database calls.

```ts
// ✅ CORRECT
export const GoalsController = {

  async list(req: Request, res: Response) {
    const { user } = req as AuthRequest;
    const page = Number(req.query.page) || 1;
    const result = await GoalsService.getUserGoals(user.id, page);
    res.json(result);
  },

  async create(req: Request, res: Response) {
    const { user } = req as AuthRequest;
    const goal = await GoalsService.create(user, req.body);
    res.status(201).json({ data: goal });
  },

  async update(req: Request, res: Response) {
    const { user } = req as AuthRequest;
    const goal = await GoalsService.update(user.id, req.params.id, req.body);
    res.json({ data: goal });
  },

  async delete(req: Request, res: Response) {
    const { user } = req as AuthRequest;
    await GoalsService.delete(user.id, req.params.id);
    res.json({ success: true });
  },

};

// ❌ WRONG — database call داخل controller
