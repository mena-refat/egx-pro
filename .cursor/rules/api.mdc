## 6. Input Validation

كل input لازم يتـ validate بـ Zod قبل أي حاجة تانية.

```ts
// ✅ CORRECT — validate في بداية الـ service
export const GoalsService = {
  async create(user: AuthUser, body: unknown) {
    const data = goalSchema.parse(body); // ZodError لو invalid
    ...
  }
};

// ✅ Zod schemas في server/lib/validations.ts
export const goalSchema = z.object({
  title:          z.string().min(1).max(100),
  targetAmount:   z.number().positive().max(100_000_000),
  currentAmount:  z.number().min(0).max(100_000_000).default(0),
  currency:       z.string().length(3).default('EGP'),
  category:       z.string().min(1).max(50),
  deadline:       z.string().datetime().optional(),
  monthlyTarget:  z.number().positive().optional(),
});

export const goalUpdateSchema = goalSchema.partial();

// ❌ WRONG — استخدام req.body مباشرة
export const GoalsService = {
  async create(userId: string, body: any) { // ❌
    return GoalsRepository.create(userId, body); // ❌ unvalidated data
  }
};
```

