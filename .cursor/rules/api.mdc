## 4. Repository Rules

Repository = كل الـ database queries. مفيش logic. مفيش validation.

```ts
// ✅ CORRECT
export const GoalsRepository = {

  async findByUser(userId: string, page: number, limit: number) {
    const skip = (page - 1) * limit;
    const [items, total] = await Promise.all([
      prisma.goal.findMany({
        where: { userId },
        orderBy: { createdAt: 'desc' },
        skip,
        take: limit,
      }),
      prisma.goal.count({ where: { userId } }),
    ]);
    return {
      items,
      pagination: { page, limit, total, totalPages: Math.ceil(total / limit) },
    };
  },

  // ownership check مدمج في الـ query نفسه
  async findOwned(id: string, userId: string) {
    return prisma.goal.findUnique({ where: { id, userId } });
  },

  async create(userId: string, data: GoalCreateInput) {
    return prisma.goal.create({ data: { userId, ...data } });
  },

  async update(id: string, data: GoalUpdateInput) {
    return prisma.goal.update({ where: { id }, data });
  },

  async delete(id: string) {
    return prisma.goal.delete({ where: { id } });
  },

  async enforceLimit(userId: string) {
    const count = await prisma.goal.count({ where: { userId } });
    if (count >= FREE_LIMITS.goals) {
      throw new AppError('GOAL_LIMIT_REACHED', 403);
    }
  },

};

// ❌ WRONG — business logic داخل repository
export const GoalsRepository = {
  async create(userId: string, data: unknown) {
    if (!isPro(user)) { // ❌ logic مش هنا
      const count = await prisma.goal.count({ where: { userId } });
      if (count >= 3) throw new Error('limit'); // ❌ magic number
    }
    return prisma.goal.create({ data: { userId, ...data } });
  }
};
```

