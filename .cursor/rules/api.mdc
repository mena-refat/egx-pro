## 13. Constants — ممنوع Magic Numbers

```ts
// server/lib/constants.ts

export const FREE_LIMITS = {
  goals:               3,
  portfolioHoldings:   5,
  watchlist:           10,
  aiAnalysisPerMonth:  3,
} as const;

export const PLAN_PRICES = {
  pro:    149,
  yearly: 999,
} as const;

export const CACHE_TTL = {
  prices:        60,
  delayedPrices: 600,
  news:          300,
  market:        300,
  profile:       600,
} as const;

export const RATE_LIMITS = {
  login:    { max: 5,   windowMs: 15 * 60 * 1000 },
  register: { max: 3,   windowMs: 60 * 60 * 1000 },
  refresh:  { max: 10,  windowMs: 60 * 1000 },
  api:      { max: 100, windowMs: 60 * 1000 },
} as const;

export const ONE_MINUTE_MS  = 60 * 1000;
export const ONE_HOUR_MS    = 60 * 60 * 1000;
export const ONE_DAY_MS     = 24 * 60 * 60 * 1000;
export const THIRTY_DAYS_MS = 30 * ONE_DAY_MS;
export const ONE_YEAR_MS    = 365 * ONE_DAY_MS;
```

