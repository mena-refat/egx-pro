## 1. System Architecture

### 1.1 Backend Layer Structure

Every backend feature must follow this exact structure. No exceptions.

```
server/
  routes/          ← HTTP routing ONLY — no logic
  controllers/     ← request/response ONLY — no business logic
  services/        ← ALL business logic lives here
  repositories/    ← ALL database queries live here
  middleware/      ← auth, validation, rate limiting
  lib/             ← shared utilities (logger, redis, prisma, constants)
  services/        ← external services (email, AI, market data)
```

#### Controller — request/response only:
```ts
// ✅ CORRECT
export const GoalsController = {
  async create(req: AuthRequest, res: Response) {
    const result = await GoalsService.create(req.user, req.body);
    res.status(201).json(result);
  },
  async list(req: AuthRequest, res: Response) {
    const page = Number(req.query.page) || 1;
    const result = await GoalsService.getUserGoals(req.user.id, page);
    res.json(result);
  }
};

// ❌ WRONG — business logic inside controller
export const GoalsController = {
  async create(req: AuthRequest, res: Response) {
    const count = await prisma.goal.count({ where: { userId: req.user.id } });
    if (count >= 3) return res.status(403).json({ error: 'limit reached' });
    const goal = await prisma.goal.create({ data: req.body });
    res.status(201).json(goal);
  }
};
```

#### Service — business logic only:
```ts
// ✅ CORRECT
export const GoalsService = {
  async create(user: AuthUser, body: unknown) {
    const data = goalSchema.parse(body);
    if (!isPro(user)) await GoalsRepository.enforceLimit(user.id);
    const goal = await GoalsRepository.create(user.id, data);
    await AchievementService.checkGoalAchievements(user.id);
    return goal;
  }
};
```

#### Repository — database only:
```ts
// ✅ CORRECT
export const GoalsRepository = {
  async create(userId: string, data: GoalCreateInput) {
    return prisma.goal.create({ data: { userId, ...data } });
  },
  async findByUser(userId: string, page: number, limit: number) {
    const skip = (page - 1) * limit;
    const [items, total] = await Promise.all([
      prisma.goal.findMany({ where: { userId }, skip, take: limit }),
      prisma.goal.count({ where: { userId } })
    ]);
    return { items, pagination: { page, limit, total, totalPages: Math.ceil(total / limit) } };
  },
  async enforceLimit(userId: string) {
    const count = await prisma.goal.count({ where: { userId } });
    if (count >= FREE_LIMITS.goals) {
      throw new AppError('GOAL_LIMIT_REACHED', 403);
    }
  }
};
```

### 1.2 Frontend Layer Structure

```
src/
  pages/            ← route-level components, max 100 lines, orchestration only
  components/
    features/       ← feature-specific components (goals/, portfolio/, stocks/)
    shared/         ← reusable: Button, Input, EmptyState, PageLoader, ErrorBoundary
    layout/         ← Sidebar, Header, BottomNav, SettingsLayout
  hooks/            ← ALL data fetching and state logic (useGoals, usePortfolio...)
  lib/
    constants.ts    ← ALL magic numbers and config values
    validations.ts  ← ALL Zod schemas
    api.ts          ← axios instance
    auth/           ← token management
  store/
    authStore.ts    ← Zustand auth store
  types/            ← shared TypeScript interfaces
```

#### Page — orchestration only, max 100 lines:
```tsx
// ✅ CORRECT
export default function GoalsPage() {
  const { goals, loading, error, addGoal, refetch } = useGoals();

  if (loading) return <SkeletonList />;
  if (error) return <ErrorMessage message={error} onRetry={refetch} />;
  if (goals.length === 0) return (
    <EmptyState icon={Target} title={t('goals.emptyTitle')} actionLabel={t('goals.addFirst')} onAction={() => setAddModalOpen(true)} />
  );

  return (
    <div>
      <GoalsList goals={goals} />
      <GoalFormModal onSubmit={addGoal} />
    </div>
  );
}

// ❌ WRONG — page has fetch logic + raw JSX mixed together
export default function GoalsPage() {
  const [goals, setGoals] = useState([]);
  const [loading, setLoading] = useState(true);
  useEffect(() => {
    fetch('/api/goals').then(r => r.json()).then(d => setGoals(d.items)).finally(() => setLoading(false));
  }, []);
  return <div>{goals.map(g => <div key={g.id} className="bg-white border border-gray-200 p-4">{g.title}</div>)}</div>;
}
```

#### Custom Hook — all data logic, max 80 lines:
```ts
// ✅ CORRECT
export function useGoals() {
  const [goals, setGoals] = useState<Goal[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const { accessToken } = useAuthStore();

  const fetchGoals = useCallback(async (signal?: AbortSignal) => {
    if (!accessToken) return;
    setLoading(true);
    setError(null);
    try {
      const res = await api.get('/goals', { signal });
      setGoals(res.data.items);
    } catch (err: unknown) {
      if ((err as { code?: string }).code === 'ERR_CANCELED') return;
      setError(t('errors.loadFailed'));
    } finally {
      setLoading(false);
    }
  }, [accessToken]);

  useEffect(() => {
    const controller = new AbortController();
    fetchGoals(controller.signal);
    return () => controller.abort();
  }, [fetchGoals]);

  return { goals, loading, error, refetch: fetchGoals };
}
```

