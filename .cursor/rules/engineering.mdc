## 7. Performance Rules

### 7.1 Database — Always Add Indexes for userId

```prisma
// ✅ CORRECT — every model that queries by userId must have index
model Goal {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("active")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                // required
  @@index([userId, status])        // for filtered queries
  @@index([userId, createdAt])     // for sorted queries
}

// ❌ WRONG — no index = full table scan on every request
model Goal {
  id     String @id
  userId String
  // missing @@index([userId])
}
```

### 7.2 Never N+1 Queries — Use Bulk Operations

```ts
// ✅ CORRECT
const tickers = holdings.map(h => h.ticker);
const prices = await getBulkPrices(tickers); // 1 request for all

// ❌ WRONG — 1 request per stock
for (const holding of holdings) {
  const price = await getStockPrice(holding.ticker); // N requests
}
```

### 7.3 Always Use Redis Cache for Expensive Operations

```ts
// ✅ CORRECT
export async function getStockPrice(ticker: string) {
  const cacheKey = `price:${ticker}`;
  const cached = await getCache(cacheKey);
  if (cached) return cached as StockPrice;

  const fresh = await marketDataService.getQuote(ticker);
  if (fresh) await setCache(cacheKey, quoteToCached(fresh), CACHE_TTL.prices);
  return fresh;
}

// ❌ WRONG — hits external API on every request without cache
export async function getStockPrice(ticker: string) {
  return marketDataService.getQuote(ticker);
}
```

### 7.4 Always Use React.lazy for Heavy Pages

```tsx
// ✅ CORRECT — in App.tsx
const StockScreener     = lazy(() => import('./components/StockScreener'));
const StockAnalysis     = lazy(() => import('./components/StockAnalysis'));
const MarketPage        = lazy(() => import('./pages/MarketPage'));
const GoalsPage         = lazy(() => import('./pages/GoalsPage'));
const StockDetailPage   = lazy(() => import('./pages/StockDetailPage'));
const PortfolioTracker  = lazy(() => import('./components/PortfolioTracker'));
const InvestmentCalculator = lazy(() => import('./components/InvestmentCalculator'));

// Always wrap with Suspense
<Suspense fallback={<PageLoader />}>
  <StockScreener />
</Suspense>

// ❌ WRONG — static import loads everything upfront
import StockScreener from './components/StockScreener';
import MarketPage from './pages/MarketPage';
```

