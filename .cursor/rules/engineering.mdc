## 2. Component Rules

### 2.1 Size Limits

| Component Type | Max Lines |
|---|---|
| Page component | 100 |
| Feature component | 200 |
| Shared component | 150 |
| Custom hook | 80 |
| Any function | 40 |
| Controller method | 15 |
| Service method | 30 |
| Repository method | 20 |

If a file exceeds the limit — split it.

### 2.2 Always Use Design System Components

```tsx
// ✅ CORRECT
import { Button } from '@/components/shared/Button';
import { Input } from '@/components/shared/Input';

<Button variant="primary" loading={isSubmitting} disabled={isSubmitting}>
  {t('goals.save')}
</Button>
<Input
  {...register('title')}
  error={errors.title?.message}
  placeholder={t('goals.titlePlaceholder')}
/>

// ❌ WRONG — raw HTML with hardcoded styles
<button className="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700">
  حفظ
</button>
<input className="border border-gray-300 rounded px-3 py-2 w-full" />
```

### 2.3 Always Use CSS Variables — Never Hardcode Colors

All colors must come from the design tokens defined in `index.css`.

```tsx
// ✅ CORRECT
<div className="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl">
<p className="text-[var(--text-primary)]">عنوان</p>
<p className="text-[var(--text-secondary)]">وصف</p>
<span className="text-[var(--success)]">+2.5%</span>
<span className="text-[var(--danger)]">-1.2%</span>
<button className="bg-[var(--brand)] hover:bg-[var(--brand-hover)] text-white">
<div className="bg-[var(--success-bg)] text-[var(--success-text)]">

// ❌ WRONG — hardcoded colors anywhere
<div className="bg-white border-gray-200">
<span className="text-green-500">+2.5%</span>
<span className="text-red-500">-1.2%</span>
<button className="bg-purple-600 hover:bg-purple-700">
<div style={{ color: '#7c3aed', background: '#fff' }}>
```

Available CSS variables:
```
Backgrounds: --bg-primary, --bg-secondary, --bg-card, --bg-card-hover, --bg-input, --bg-sidebar, --bg-header
Text:        --text-primary, --text-secondary, --text-muted, --text-disabled, --text-inverse
Brand:       --brand, --brand-hover, --brand-subtle, --brand-text
Status:      --success, --success-bg, --success-text
             --danger, --danger-bg, --danger-text
             --warning, --warning-bg, --warning-text
Borders:     --border, --border-subtle, --border-strong
Shadows:     --shadow-sm, --shadow-md, --shadow-lg
```

### 2.4 Always Wrap useEffect Fetch with AbortController

```tsx
// ✅ CORRECT
useEffect(() => {
  const controller = new AbortController();

  const load = async () => {
    try {
      const res = await api.get('/endpoint', { signal: controller.signal });
      setData(res.data);
    } catch (err: unknown) {
      if ((err as { code?: string }).code === 'ERR_CANCELED') return;
      setError('فشل التحميل');
    } finally {
      setLoading(false);
    }
  };

  load();
  return () => controller.abort();
}, [dependency]);

// ❌ WRONG — no cleanup, causes memory leak and state updates on unmounted component
useEffect(() => {
  api.get('/endpoint').then(res => setData(res.data));
}, []);
```

### 2.5 Always Clean Up Event Listeners and Timers

```tsx
// ✅ CORRECT — event listener
useEffect(() => {
  const handler = (e: MouseEvent) => { ... };
  document.addEventListener('mousedown', handler);
  return () => document.removeEventListener('mousedown', handler);
}, []);

// ✅ CORRECT — timeout
useEffect(() => {
  const id = setTimeout(() => setVisible(false), TIMEOUTS.toast);
  return () => clearTimeout(id);
}, []);

// ✅ CORRECT — interval
useEffect(() => {
  const id = setInterval(fetchPrices, CACHE_TTL.prices * 1000);
  return () => clearInterval(id);
}, []);

// ❌ WRONG — no cleanup
useEffect(() => {
  window.addEventListener('resize', handleResize);
  setTimeout(() => setVisible(false), 3000);
}, []);
```

### 2.6 Memoize Heavy Components and Callbacks

```tsx
// ✅ CORRECT
const StockCard = memo(function StockCard({ stock, onAdd }: StockCardProps) {
  return <div>...</div>;
});

// In parent:
const handleAddToWatchlist = useCallback((ticker: string) => {
  addToWatchlist(ticker);
}, [addToWatchlist]);

const sortedStocks = useMemo(() =>
  [...stocks].sort((a, b) => b.changePercent - a.changePercent),
  [stocks]
);

// ❌ WRONG — new function/object created every render, breaks memo
<StockCard onAdd={(ticker) => addToWatchlist(ticker)} />
<StockCard options={{ showChart: true }} />
```

### 2.7 Forms Always Use react-hook-form + Zod

```tsx
// ✅ CORRECT
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { goalSchema } from '@/lib/validations';

type GoalFormData = z.infer<typeof goalSchema>;

const {
  register,
  handleSubmit,
  formState: { errors, isSubmitting },
  reset,
} = useForm<GoalFormData>({ resolver: zodResolver(goalSchema) });

const onSubmit = async (data: GoalFormData) => {
  await createGoal(data);
  reset();
};

// ❌ WRONG — manual state for forms
const [title, setTitle] = useState('');
const [amount, setAmount] = useState('');
const [error, setError] = useState('');
```

### 2.8 Always Show Loading, Error, and Empty States

```tsx
// ✅ CORRECT — all 3 states handled
if (loading) return <SkeletonList count={5} />;
if (error) return <ErrorMessage message={error} onRetry={refetch} />;
if (items.length === 0) return (
  <EmptyState
    icon={Target}
