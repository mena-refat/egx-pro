## 4. TypeScript Rules

### 4.1 No `any` — Use Explicit Types

```ts
// ✅ CORRECT
async function getUser(id: string): Promise<User | null> {
  return prisma.user.findUnique({ where: { id } });
}
const userId = (req as AuthRequest).user.id;

// ❌ WRONG
async function getUser(id: any) { ... }
const userId = (req as any).user?.id;
```

### 4.2 No Non-Null Assertion Without a Guard

```ts
// ✅ CORRECT
if (!user?.id) throw new AppError('UNAUTHORIZED', 401);
const id = user.id; // safe after guard

// ❌ WRONG — crashes if user is null
const id = user!.id;
const name = data!.user!.fullName!;
```

### 4.3 Always Type Component Props

```tsx
// ✅ CORRECT
interface StockCardProps {
  stock: Stock;
  isInWatchlist: boolean;
  onAddToWatchlist: (ticker: string) => void;
  onRemoveFromWatchlist: (ticker: string) => void;
}

const StockCard = memo(function StockCard({
  stock,
  isInWatchlist,
  onAddToWatchlist,
  onRemoveFromWatchlist,
}: StockCardProps) {
  return <div>...</div>;
});

// ❌ WRONG
function StockCard({ stock, onAdd, onRemove }: any) { ... }
function StockCard(props: any) { ... }
```

### 4.4 Use AuthRequest Type for Protected Routes

```ts
// ✅ CORRECT
import type { AuthRequest } from '../routes/types';

router.get('/', authenticate, async (req: Request, res: Response) => {
  const { user } = req as AuthRequest;
  const goals = await GoalsService.getUserGoals(user.id);
  res.json(goals);
});

// ❌ WRONG
const userId = ('user' in req && (req as { user?: { id?: string } }).user?.id);
```

