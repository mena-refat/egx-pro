## 5. Security Rules

### 5.1 Always Validate Input with Zod

```ts
// ✅ CORRECT — validate at route entry
router.post('/goals', authenticate, async (req: Request, res: Response) => {
  const data = goalSchema.parse(req.body); // throws ZodError if invalid
  const result = await GoalsService.create((req as AuthRequest).user, data);
  res.status(201).json(result);
});

// ❌ WRONG — using req.body directly
router.post('/goals', authenticate, async (req: Request, res: Response) => {
  const goal = await prisma.goal.create({ data: req.body });
  res.json(goal);
});
```

### 5.2 Always Verify Resource Ownership

```ts
// ✅ CORRECT — userId enforced in the query itself
const goal = await prisma.goal.findUnique({
  where: { id, userId: req.user.id }
});
if (!goal) return res.status(404).json({ error: 'NOT_FOUND' });

// ❌ WRONG — anyone can access any resource by ID
const goal = await prisma.goal.findUnique({ where: { id } });
```

### 5.3 Always Use authenticate Middleware

```ts
// ✅ CORRECT
router.get('/',     authenticate, GoalsController.list);
router.post('/',    authenticate, GoalsController.create);
router.put('/:id',  authenticate, GoalsController.update);
router.delete('/:id', authenticate, GoalsController.delete);

// ❌ WRONG — missing auth
router.get('/', GoalsController.list);
router.post('/upgrade', async (req, res) => { ... }); // unprotected billing!
```

### 5.4 Never Log Sensitive Data

```ts
// ✅ CORRECT
logger.info('User logged in', { userId: user.id, ip: req.ip });
logger.error('Auth failed', { email: user.email, reason: 'invalid_password' });

// ❌ WRONG
logger.info('Login attempt', { password: req.body.password });
logger.debug('Token issued', { token: accessToken });
logger.error('Error', { secret: process.env.JWT_SECRET });
```

### 5.5 All String Inputs Must Have max() Limit

```ts
// ✅ CORRECT
const goalSchema = z.object({
  title:        z.string().min(1).max(100),
  category:     z.string().min(1).max(50),
  targetAmount: z.number().positive().max(100_000_000),
  currency:     z.string().length(3),
  deadline:     z.string().datetime().optional(),
});

// ❌ WRONG — no max limit, allows huge payloads
const goalSchema = z.object({
  title:        z.string().min(1),
  targetAmount: z.number(),
});
```

