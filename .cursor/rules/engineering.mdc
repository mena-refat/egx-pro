## 3. Constants — Never Use Magic Numbers

All numbers, prices, limits, and durations must be named constants.

### `src/lib/constants.ts` and `server/lib/constants.ts`:

```ts
// ✅ CORRECT — import from constants
import { PLAN_PRICES, FREE_LIMITS, TIMEOUTS, CACHE_TTL } from '@/lib/constants';

if (count >= FREE_LIMITS.goals) throw new AppError('GOAL_LIMIT_REACHED', 403);
const price = PLAN_PRICES.pro;
const id = setTimeout(fn, TIMEOUTS.toast);
await setCache(key, data, CACHE_TTL.prices);

// ❌ WRONG — magic numbers scattered everywhere
if (count >= 3) ...
const price = 149;
setTimeout(fn, 3000);
setCache(key, data, 60);
```

### Required constants:
```ts
// src/lib/constants.ts
export const PLAN_PRICES = {
  pro: 149,
  yearly: 999,
} as const;

export const FREE_LIMITS = {
  goals: 3,
  portfolioHoldings: 5,
  watchlist: 10,
  aiAnalysisPerMonth: 3,
} as const;

export const TIMEOUTS = {
  toast: 3000,
  debounce: 300,
  retry: 1000,
  sessionCheck: 5 * 60 * 1000,
} as const;

export const CACHE_TTL = {
  prices: 60,          // seconds
  delayedPrices: 600,
  news: 300,
  profile: 600,
  market: 300,
} as const;

// server/lib/constants.ts
export const ONE_MINUTE_MS  = 60 * 1000;
export const ONE_HOUR_MS    = 60 * 60 * 1000;
export const ONE_DAY_MS     = 24 * 60 * 60 * 1000;
export const THIRTY_DAYS_MS = 30 * ONE_DAY_MS;

export const RATE_LIMITS = {
  login:    { max: 5,   windowMs: 15 * ONE_MINUTE_MS },
  register: { max: 3,   windowMs: ONE_HOUR_MS },
  refresh:  { max: 10,  windowMs: ONE_MINUTE_MS },
  api:      { max: 100, windowMs: ONE_MINUTE_MS },
} as const;
```

