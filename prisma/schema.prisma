generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Stock {
  id                 String      @id @default(cuid())
  ticker             String      @unique
  nameAr             String
  nameEn             String
  sector             GicsSector?
  description        String?     /// وصف منظم للنشاط والقطاع (عربي)
  isShariaCompliant  Boolean?    /// true = متوافق مع الشريعة، false = غير متوافق، null = غير محدد

  @@index([sector])
  @@index([isShariaCompliant])
}

model User {
  id                                     String         @id @default(uuid())
  email                                  String?        @unique
  phone                                  String?        @unique
  passwordHash                           String?
  salt                                   String?
  fullName                               String?
  username                               String?        @unique
  isEmailVerified                        Boolean        @default(false)
  twoFactorEnabled                       Boolean        @default(false)
  twoFactorSecret                        String?
  twoFactorEnabledAt                     DateTime?
  avatarUrl                              String?
  riskTolerance                          String?        @default("moderate")
  investmentHorizon                      Int?           @default(5)
  monthlyBudget                          Float?         @default(0)
  shariaMode                             Boolean        @default(false)
  onboardingCompleted                    Boolean        @default(false)
  interestedSectors                      String?        @default("[]")
  language                               String         @default("system")
  theme                                  String         @default("system")
  plan                                   String         @default("free")
  planExpiresAt                          DateTime?
  aiAnalysisUsedThisMonth                Int            @default(0)
  aiAnalysisResetDate                    DateTime?
  planSetByAdmin                         Boolean        @default(false)
  mustChangePassword Boolean        @default(false)
  mustSetup2FA       Boolean        @default(false)
  pwdMinLength       Boolean        @default(false)
  pwdUppercase       Boolean        @default(false)
  pwdLowercase       Boolean        @default(false)
  pwdSymbols         Boolean        @default(false)
  referralCode                           String?        @unique
  referredBy                             String?
  referralUsed                           String?
  totalReferrals                         Int            @default(0)
  referralProDaysRemaining               Int            @default(0)
  referralProExpiresAt                   DateTime?
  notifySignals                          Boolean        @default(true)
  notifyPortfolio                        Boolean        @default(true)
  notifyNews                             Boolean        @default(true)
  notifyAchievements                     Boolean        @default(true)
  notifyGoals                            Boolean        @default(true)
  lastLoginAt                            DateTime?
  lastLoginIp                            String?
  loginStreak                            Int            @default(0)
  freeReferralRewarded                   Boolean        @default(false)
  lastPasswordChangeAt                   DateTime?
  lastUsernameChangeAt                   DateTime?
  usernameChangeCount                    Int            @default(0)
  isDeleted                              Boolean        @default(false)
  deletedAt                              DateTime?
  deletionScheduledFor                   DateTime?
  isFirstLogin                           Boolean        @default(true)
  hearAboutUs                            String?
  investorProfile                        Json?
  userTitle                              String         @default("ناشئ")
  failedLoginAttempts                    Int            @default(0)
  lockedUntil                            DateTime?
  unseenAchievements                     String[]       @default([])
  isPrivate                              Boolean        @default(true)
  showPortfolio                          Boolean        @default(true)
  createdAt                              DateTime       @default(now())
  updatedAt                              DateTime       @updatedAt
  analyses                               Analysis[]
  auditLogs                              AuditLog[]
  discountUsages                         DiscountUsage[]
  followsReceived                        Follow[]       @relation("FollowFollowing")
  followsSent                            Follow[]       @relation("FollowFollower")
  goals                                  Goal[]
  idempotencyKeys                        IdempotencyKey[]
  notifications                          Notification[]
  portfolios                             Portfolio[]
  predictionLikes                        PredictionLike[]
  predictions                            Prediction[]
  predictionStats                        UserPredictionStats?
  Referral_Referral_referredUserIdToUser Referral[]     @relation("Referral_referredUserIdToUser")
  referralsSent                          Referral[]     @relation("ReferralsSent")
  refreshTokens                          RefreshToken[]
  watchlists                             Watchlist[]
  supportTickets                         SupportTicket[]
  pushToken                              String?
  pushPlatform                           String?

  @@index([isDeleted, deletionScheduledFor])
  @@index([plan, planExpiresAt])
  @@index([username])
  @@index([createdAt])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  salt         String
  fullName     String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  permissions  String[]  @default([])
  twoFactorEnabled      Boolean  @default(false)
  twoFactorSecret       String?
  mustChangePassword Boolean  @default(false)
  mustSetup2FA       Boolean  @default(false)
  pwdMinLength       Boolean  @default(false)
  pwdUppercase       Boolean  @default(false)
  pwdLowercase       Boolean  @default(false)
  pwdSymbols         Boolean  @default(false)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  auditLogs    AdminAuditLog[]
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model BlockedIdentifier {
  id        String   @id @default(cuid())
  type      String   // EMAIL | PHONE | EMAIL_DOMAIN
  value     String
  reason    String?
  blockedBy String?
  createdAt DateTime @default(now())

  @@unique([type, value])
  @@index([type])
}

model SupportTicket {
  id          String              @id @default(cuid())
  userId      String
  subject     String
  message     String
  status      SupportTicketStatus @default(OPEN)
  priority    TicketPriority      @default(NORMAL)
  assignedTo  String?
  reply       String?
  repliedAt   DateTime?
  repliedBy   String?
  replyRead   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  deviceInfo String?
  deviceType String?
  browser    String?
  os         String?
  ipAddress  String?
  city       String?
  country    String?
  isRevoked  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRevoked, expiresAt])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  ipHash    String?
  result    String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
}

model Portfolio {
  id        String   @id @default(uuid())
  userId    String
  ticker    String
  shares    Float
  avgPrice  Float
  buyDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, ticker])
  @@index([ticker])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float     @default(0)
  currency      String    @default("EGP")
  deadline      DateTime?
  category      String
  status        String    @default("active")
  achievedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([deadline])
}

model Watchlist {
  id                      String    @id @default(uuid())
  userId                  String
  ticker                  String
  targetPrice             Float?
  targetReachedNotifiedAt DateTime?
  createdAt               DateTime  @default(now())
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, ticker])
  @@index([userId, ticker])
}

model Analysis {
  id              String    @id @default(uuid())
  userId          String
  ticker          String
  content         String
  createdAt       DateTime  @default(now())
  priceAtAnalysis Float?
  targetPrice     Float?
  stopLoss        Float?
  verdict         String?
  priceAfter7d    Float?
  priceAfter30d   Float?
  accuracyScore   Float?
  accuracyNote    String?
  checkedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, ticker])
  @@index([checkedAt])
  @@index([createdAt])
  @@index([ticker, createdAt])
}

model Referral {
  id                                 String   @id @default(cuid())
  referrerId                         String
  referredUserId                     String
  status                             String   @default("pending")
  createdAt                          DateTime @default(now())
  User_Referral_referredUserIdToUser User     @relation("Referral_referredUserIdToUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer                           User     @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referredUserId])
  @@index([referrerId, status, createdAt])
}

enum FollowStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum PredictionDir {
  UP
  DOWN
}

enum PredictionTime {
  WEEK
  MONTH
  THREE_MONTHS
  SIX_MONTHS
  NINE_MONTHS
  YEAR
}

enum PredictionStatus {
  ACTIVE
  HIT
  MISSED
  EXPIRED
}

enum UserRank {
  BEGINNER
  ANALYST
  SENIOR
  EXPERT
  LEGEND
}

model Follow {
  id          String       @id @default(cuid())
  followerId  String
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  follower    User         @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User         @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, status])
}

model Prediction {
  id              String           @id @default(cuid())
  userId          String
  ticker          String
  direction       PredictionDir
  targetPrice     Float
  priceAtCreation Float
  timeframe       PredictionTime
  reason          String?
  expiresAt       DateTime
  isPublic        Boolean         @default(true)
  status          PredictionStatus @default(ACTIVE)
  resolvedAt      DateTime?
  resolvedPrice   Float?
  pointsEarned    Int?
  accuracyPct     Float?
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes           PredictionLike[]

  @@index([userId])
  @@index([userId, status])
  @@index([ticker, status])
  @@index([status, isPublic])
  @@index([resolvedAt])
  @@index([status, expiresAt])
  @@index([userId, createdAt])
}

model PredictionLike {
  predictionId String
  userId       String
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([predictionId, userId])
  @@index([userId])
}

model UserPredictionStats {
  userId            String   @id
  totalPredictions   Int      @default(0)
  correctPredictions Int     @default(0)
  totalPoints        Int      @default(0)
  accuracyRate       Float   @default(0)
  currentStreak      Int     @default(0)
  bestStreak         Int     @default(0)
  rank               UserRank @default(BEGINNER)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiscountUsage {
  userId       String
  codeId       String
  discountCode DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, codeId])
  @@index([codeId])
}

model DiscountCode {
  id           String          @id @default(uuid())
  code         String          @unique
  type         String
  value        Float
  active       Boolean         @default(true)
  expiresAt    DateTime?
  maxUses      Int?
  usedCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  discountUsages DiscountUsage[]

  @@index([active, expiresAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  route     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model NewsItem {
  id           String         @id @default(cuid())
  externalId   String         @unique
  title        String
  summary      String?
  source       String
  sourceType   NewsSourceType
  url          String
  publishedAt  DateTime
  fetchedAt    DateTime       @default(now())
  isMarketWide Boolean        @default(false)
  language     String?
  sentiment    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tickers      NewsTicker[]

  @@index([publishedAt])
  @@index([sourceType, publishedAt])
  @@index([isMarketWide, publishedAt])
}

model NewsTicker {
  newsId  String
  ticker  String
  news    NewsItem @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@id([newsId, ticker])
  @@index([ticker])
}

model IdempotencyKey {
  id             String   @id @default(cuid())
  userId         String
  key            String
  method         String
  path           String
  requestHash    String
  status         String   @default("PROCESSING")
  responseStatus Int?
  responseBody   Json?
  lockedAt       DateTime
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, status, expiresAt])
  @@index([expiresAt])
}

model ArchivedUser {
  id         String   @id @default(uuid())
  originalId String   @unique
  email      String?
  phone      String?
  username   String?
  name       String?
  userData   Json
  archivedAt DateTime @default(now())
}

enum GicsSector {
  INFORMATION_TECHNOLOGY
  HEALTH_CARE
  FINANCIALS
  CONSUMER_DISCRETIONARY
  CONSUMER_STAPLES
  ENERGY
  INDUSTRIALS
  MATERIALS
  UTILITIES
  REAL_ESTATE
  COMMUNICATION_SERVICES
}

enum NewsSourceType {
  NEWS_API
  GOOGLE_RSS
  EGX_DISCLOSURE
}
