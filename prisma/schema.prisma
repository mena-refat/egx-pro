generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String?
  salt              String?
  fullName          String?
  username          String?   @unique
  isEmailVerified   Boolean   @default(false)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  avatarUrl         String?
  riskTolerance     String?   @default("moderate")
  investmentHorizon Int?      @default(5)
  monthlyBudget     Float?    @default(0)
  shariaMode        Boolean   @default(false)
  islamicMode       Boolean   @default(false)
  onboardingCompleted Boolean @default(false)
  interestedSectors   String?   @default("[]")
  language          String    @default("system")
  theme             String    @default("system")
  subscriptionPlan  String    @default("free") // free, pro, annual
  subscriptionEndsAt DateTime?
  plan              String    @default("free") // "free" | "pro" | "yearly"
  analysisUsageMonth String?   // e.g. "2026-03"
  analysisUsageCount Int       @default(0)
  aiAnalysisUsedThisMonth Int  @default(0)
  aiAnalysisResetDate    DateTime?
  referralCode      String?   @unique
  referredBy        String?
  referralUsed      String?
  totalReferrals    Int       @default(0)
  referralProDaysRemaining Int @default(0)
  referralProExpiresAt DateTime?
  notifySignals     Boolean   @default(true)
  notifyPortfolio   Boolean   @default(true)
  notifyNews        Boolean   @default(true)
  notifyAchievements Boolean  @default(true)
  notifyGoals       Boolean   @default(true)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  loginStreak       Int       @default(0)
  freeReferralRewarded Boolean @default(false)
  lastPasswordChangeAt DateTime?
  lastUsernameChangeAt DateTime?
  usernameChangeCount Int       @default(0)
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  deletionScheduledFor DateTime?
  isFirstLogin      Boolean   @default(true)
  hearAboutUs       String?
  investorProfile   Json?
  userTitle         String    @default("ناشئ") // ناشئ | مستثمر | محترف | أسطورة
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?
  unseenAchievements String[] @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  portfolios         Portfolio[]
  goals              Goal[]
  watchlists         Watchlist[]
  analyses           Analysis[]
  referralsSent      Referral[] @relation("ReferralsSent")
  referralsReceived  Referral[] @relation("ReferralsReceived")
  notifications      Notification[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique // hash of the refresh token (for lookup)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  deviceInfo String?   // legacy raw UA; prefer deviceType/browser/os
  deviceType String?   // desktop | mobile | tablet
  browser    String?   // Chrome | Firefox | Safari | Edge | etc.
  os         String?   // Windows | macOS | iOS | Android | etc.
  ipAddress  String?
  city       String?
  country    String?
  isRevoked  Boolean   @default(false)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  ipHash    String?  // للتوافق مع الكود القديم
  result    String?  // success | failure
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
  timestamp DateTime @default(now()) // للتوافق

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Portfolio {
  id        String   @id @default(uuid())
  userId    String
  ticker    String
  shares    Float
  avgPrice  Float
  buyDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  targetAmount  Float
  currentAmount Float     @default(0)
  currency      String    @default("EGP")
  deadline      DateTime?
  category      String
  status        String    @default("active")
  achievedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Watchlist {
  id                      String    @id @default(uuid())
  userId                  String
  ticker                  String
  targetPrice             Float?
  targetReachedNotifiedAt DateTime?
  createdAt               DateTime  @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Analysis {
  id        String   @id @default(uuid())
  userId    String
  ticker    String
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id              String   @id @default(uuid())
  referrerId      String
  referredUserId  String
  status          String   @default("pending") // pending, completed
  createdAt       DateTime @default(now())

  referrer        User     @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser    User     @relation("ReferralsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
}

model DiscountCode {
  id         String   @id @default(uuid())
  code       String   @unique
  type       String   // percentage or amount
  value      Float
  active     Boolean  @default(true)
  expiresAt  DateTime?
  maxUses    Int?
  usedCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // achievement | stock_target | referral | goal | portfolio
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ArchivedUser {
  id          String   @id @default(uuid())
  originalId  String   @unique
  email       String?
  phone       String?
  username    String?
  name        String?
  userData    Json
  archivedAt  DateTime @default(now())
}
